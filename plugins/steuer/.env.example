# Wise API token (only required if using Wise as a transaction source)
# Get from: https://wise.com/settings/account → API tokens
WISE_API_TOKEN=

# Optional: account details printed in the PDF report header.
# Any subset can be set; only fields you provide are rendered.
ACCOUNT_NAME=
ACCOUNT_BANK=
# Bank postal address (appears under the bank name)
ACCOUNT_BANK_ADDRESS=
# e.g. "Checking", "Business checking"
ACCOUNT_TYPE=
# ABA / SWIFT / BIC / sort code
ACCOUNT_ROUTING=
# IBAN or local account number
ACCOUNT_NUMBER=
